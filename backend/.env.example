# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/voiceopd?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_REFRESH_EXPIRE=30d

# ── Frontend URLs (CORS) ──────────────────────────────────────────────────────
# Comma-separated — add your Vercel domain + any preview URLs
CLIENT_URL=https://your-app.vercel.app

# ── Email / SMTP (Forgot Password) ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
