    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.7.5",
    "tslib": "^2.6.2",
    "zone.js": "~0.14.4"
  },
  "devDependencies": {
